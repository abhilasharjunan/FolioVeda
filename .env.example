# Required
DATABASE_URL="postgresql://user:password@host:5432/db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Optional (Redis caching)
REDIS_URL=""

# Required for cron jobs (Vercel) — set a random secret
CRON_SECRET=""

# Email (SMTP) — required for forgot password
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@folioveda.app"